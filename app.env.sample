# Directus environment configuration

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=$HOSTNAME
BASE_DOMAIN_NAME=example.com

# Application secrets
APP_SECRET_KEY=changeme_secret_key_min_32_chars
DIRECTUS_SECRET=changeme_directus_secret_32chars

# Admin credentials
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme_admin_password

# Database (PostgreSQL)
DB_CREATE_DATABASE_NAME=directus
DB_USER_NAME=directus
DB_USER_PASS=changeme_db_password

# Email / SMTP
EMAIL_SERVER_HOST=172.17.0.1
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASS=
EMAIL_SERVER_MAIL_FROM=directus@example.com

# WebSockets (true/false)
DIRECTUS_WEBSOCKETS=true
